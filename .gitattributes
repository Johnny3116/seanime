# Ensure consistent line endings across platforms.
# Shell scripts must use LF or they will fail on Linux/macOS when cloned on Windows.

* text=auto

*.sh   text eol=lf
*.bash text eol=lf
*.ps1  text eol=crlf

*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.wasm binary
