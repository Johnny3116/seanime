# Frontend build environment variables for Seanime web app.
# Copy this file to the appropriate platform-specific .env file and adjust as needed.
#
# Platform-specific files already committed:
#   .env.web             — browser web app (default dev target)
#   .env.desktop         — Tauri desktop build
#   .env.denshi          — Electron desktop build
#   .env.mobile          — Mobile build
#   .env.development.desktop — Electron dev build

# Target platform: "web" | "desktop" | "mobile"
SEA_PUBLIC_PLATFORM="web"

# Set to "electron" for Electron builds, "tauri" for Tauri builds.
# Leave unset for web/mobile.
# SEA_PUBLIC_DESKTOP=

# Set to "true" to enable dev-only features (e.g. verbose logging).
# SEA_PUBLIC_DEVBUILD=
